{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": ["serena-mcp"],
      "tools_cache": [
        "find_symbol",
        "find_referencing_symbols",
        "get_symbols_overview",
        "get_diagnostics_for_file"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "tools_cache": ["resolve-library-id", "query-docs"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "tools_cache": ["browser_navigate", "browser_snapshot", "browser_click", "browser_fill"]
    }
  }
}

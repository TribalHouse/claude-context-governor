{
  "_comment": "Copy to registry.json and edit. Each top-level key is a backend. gov.* shortcut tools only appear when their expected backend name is registered. See docs/registry.md for the full annotated guide.",
  "_settings": {
    "exposePassthroughTools": false
  },

  "serena": {
    "description": "Code intelligence. Powers gov.search_code.",
    "transport": "streamable-http",
    "endpoint": "http://127.0.0.1:12301/mcp",
    "always_on": true,
    "disabled": false
  },

  "context7": {
    "description": "Library and framework docs. Powers gov.search_docs.",
    "transport": "streamable-http",
    "endpoint": "http://127.0.0.1:12302/mcp",
    "always_on": true,
    "disabled": false
  },

  "playwright": {
    "description": "Browser automation. Powers gov.browser_task.",
    "transport": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@playwright/mcp@latest"
    ],
    "always_on": false,
    "disabled": false,
    "idle_timeout_seconds": 300
  },

  "github": {
    "description": "GitHub repository, issue, and PR management.",
    "transport": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-github"
    ],
    "env_passthrough": [
      "GITHUB_PERSONAL_ACCESS_TOKEN"
    ],
    "always_on": false,
    "disabled": false,
    "idle_timeout_seconds": 600
  },

  "example-http-backend": {
    "description": "HTTP backend with env-var auth. Disabled until configured.",
    "transport": "streamable-http",
    "endpoint": "https://example.com/mcp",
    "headers": {
      "Authorization": "Bearer ${EXAMPLE_API_TOKEN}"
    },
    "always_on": false,
    "disabled": true,
    "idle_timeout_seconds": 600
  }
}
